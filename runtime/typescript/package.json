{
  "private": true,
  "name": "prompty-workspace",
  "description": "Prompty TypeScript monorepo",
  "workspaces": [
    "packages/core",
    "packages/openai",
    "packages/foundry",
    "packages/anthropic"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "clean": "npm run clean --workspaces",
    "release": "node scripts/release.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
