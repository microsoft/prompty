---
name: azure-responses
description: E2E test for Azure backward-compat Responses API
model:
  id: gpt-4o
  provider: azure
  apiType: responses
  connection:
    kind: reference
    name: mock-azure
  options:
    temperature: 0.7
    maxOutputTokens: 500
inputs:
  - name: name
    kind: string
    default: Seth
template:
  format:
    kind: nunjucks
  parser:
    kind: prompty
---
system:
You are a helpful assistant.

user:
Hello, my name is {{name}}.
