{
  "name": "@prompty/openai",
  "version": "2.0.0-alpha.3",
  "description": "OpenAI provider for Prompty — executor and processor for OpenAI APIs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "prompty",
    "openai",
    "llm",
    "ai"
  ],
  "author": "Microsoft",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microsoft/prompty.git",
    "directory": "runtime/typescript/packages/openai"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@prompty/core": "^2.0.0-alpha.3"
  },
  "dependencies": {
    "openai": "^4.80.0"
  },
  "devDependencies": {
    "@prompty/core": "^2.0.0-alpha.3",
    "@types/node": "^20.11.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
