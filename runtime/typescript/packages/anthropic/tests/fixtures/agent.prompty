---
name: anthropic-agent
description: E2E test for Anthropic agent loop with tool calls
model:
  id: claude-sonnet-4-5-20250929
  provider: anthropic
  apiType: chat
  connection:
    kind: reference
    name: mock-anthropic
inputs:
  - name: question
    kind: string
    default: What is the weather?
tools:
  - name: get_weather
    kind: function
    description: Get current weather
    parameters:
      - name: city
        kind: string
        description: City name
        required: true
template:
  format:
    kind: nunjucks
  parser:
    kind: prompty
---
system:
You are a helpful assistant. Use tools to answer questions.

user:
{{question}}
