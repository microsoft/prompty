{
  "name": "@prompty/anthropic",
  "version": "2.0.0-beta.5",
  "description": "Anthropic provider for Prompty — executor and processor for Anthropic Messages API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "prompty",
    "anthropic",
    "claude",
    "llm",
    "ai"
  ],
  "author": "Microsoft",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microsoft/prompty.git",
    "directory": "runtime/typescript/packages/anthropic"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.39.0",
    "@prompty/core": "^2.0.0-beta.4"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": false
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prompty/core": "^2.0.0-beta.5",
    "@types/node": "^20.11.0",
    "dotenv": "^16.4.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@prompty/core": "^2.0.0-beta.4"
  }
}
