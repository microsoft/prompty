---
name: streaming-chat
description: Chat completion with streaming enabled
model:
  id: gpt-4o-mini
  provider: openai
  apiType: chat
  connection:
    kind: key
    apiKey: ${env:OPENAI_API_KEY}
  options:
    temperature: 0.7
    maxOutputTokens: 1024
    additionalProperties:
      stream: true
inputs:
  - name: question
    kind: string
    default: Tell me a short story
template:
  format:
    kind: jinja2
  parser:
    kind: prompty
---
system:
You are a creative storyteller.

user:
{{question}}
