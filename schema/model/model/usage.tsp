import "@typra/emitter";

namespace Prompty;

/**
 * Tracks token consumption for a single LLM call. Provider-specific field
 * names (e.g., OpenAI's `prompt_tokens` vs Anthropic's `input_tokens`)
 * are mapped via `knownAs` augments in the wire directory.
 */
model TokenUsage {
  @doc("Number of tokens in the prompt/input sent to the model")
  @sample(#{ promptTokens: 150 })
  promptTokens?: int32;

  @doc("Number of tokens generated in the model's completion/output")
  @sample(#{ completionTokens: 42 })
  completionTokens?: int32;

  @doc("Total tokens consumed (prompt + completion). May be provided by the API or computed.")
  @sample(#{ totalTokens: 192 })
  totalTokens?: int32;
}

/**
 * Complete cumulative token usage for one completed model invocation.
 *
 * Providers emit this value at most once per invocation. `totalTokens` uses
 * the provider total when available; otherwise the provider adapter computes
 * it as `inputTokens + outputTokens`.
 */
model InvocationUsage {
  @doc("Number of input tokens consumed by the completed invocation")
  @sample(#{ inputTokens: 150 })
  inputTokens: int64;

  @doc("Number of output tokens generated by the completed invocation")
  @sample(#{ outputTokens: 42 })
  outputTokens: int64;

  @doc("Total tokens consumed by the completed invocation")
  @sample(#{ totalTokens: 192 })
  totalTokens: int64;
}
