    hideEmptyMembersBox: true
---
classDiagram
    {%- for type in types %}
    class {{ type.typeName.name }} {
      {% if type.isAbstract %}<<abstract>>{% endif %}
      {%- for prop in type.properties %}
        +{{ prop.typeName.name }}{{ "[]" if prop.isCollection else "" }} {{ prop.name }}
      {%- endfor %}
    }
    {%- endfor -%}
    {%- for child in childTypes %}
    {{ child.source }} <|-- {{ child.target }}
    {%- endfor -%}
    {%- for comp in compositionTypes %}
    {{ comp.source }} *-- {{ comp.target }}
    {%- endfor %}
