        "data": [
          {
            "object": "embedding",
            "index": 0,
            "embedding": [0.1, 0.2, 0.3]
          }
        ],
        "model": "text-embedding-3-small",
        "usage": {
          "prompt_tokens": 5,
          "total_tokens": 5
        }
      },
      "has_outputs": false
    },
    "expected": {
      "result": [0.1, 0.2, 0.3]
    }
  },
  {
    "name": "embedding_batch",
    "description": "Batch embedding response with 3 inputs — returns list of 3 vectors",
