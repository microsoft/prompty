[
  {
    "name": "chat_text_content",
    "description": "Basic chat completion with text content — extracts the message string",
    "input": {
      "provider": "openai",
      "apiType": "chat",
      "response": {
        "id": "chatcmpl-abc123",
        "object": "chat.completion",
        "created": 1700000000,
        "model": "gpt-4o-mini",
        "choices": [
          {
            "index": 0,
            "message": {
              "role": "assistant",
              "content": "Hello!",
              "refusal": null
            },
            "finish_reason": "stop"
          }
        ],
        "usage": {
          "prompt_tokens": 10,
          "completion_tokens": 2,
          "total_tokens": 12
        }
      },
      "has_outputs": false
    },
    "expected": {
      "result": "Hello!"
    }
  },
  {
    "name": "chat_tool_calls",
    "description": "Chat completion with a single tool call — extracts ToolCall list",
    "input": {
      "provider": "openai",
      "apiType": "chat",
      "response": {
        "id": "chatcmpl-tool1",
        "object": "chat.completion",
        "created": 1700000001,
        "model": "gpt-4o-mini",
        "choices": [
          {
            "index": 0,
            "message": {
              "role": "assistant",
              "content": null,
              "tool_calls": [
                {
                  "id": "call_1",
                  "type": "function",
                  "function": {
                    "name": "get_weather",
                    "arguments": "{\"city\":\"Paris\"}"
                  }
                }
              ],
              "refusal": null
            },
            "finish_reason": "tool_calls"
          }
        ],
        "usage": {
          "prompt_tokens": 25,
          "completion_tokens": 15,
          "total_tokens": 40
        }
      },
      "has_outputs": false
    },
    "expected": {
      "result": [
        {
          "id": "call_1",
          "name": "get_weather",
          "arguments": "{\"city\":\"Paris\"}"
        }
      ]
    }
  },
  {
    "name": "chat_multiple_tool_calls",
    "description": "Chat completion with two parallel tool calls — extracts both ToolCall objects",
    "input": {
      "provider": "openai",
      "apiType": "chat",
      "response": {
        "id": "chatcmpl-tool2",
        "object": "chat.completion",
        "created": 1700000002,
        "model": "gpt-4o-mini",
        "choices": [
          {
            "index": 0,
            "message": {
              "role": "assistant",
              "content": null,
              "tool_calls": [
                {
                  "id": "call_a",
                  "type": "function",
                  "function": {
                    "name": "get_weather",
                    "arguments": "{\"city\":\"Paris\"}"
                  }
                },
                {
                  "id": "call_b",
                  "type": "function",
                  "function": {
                    "name": "get_time",
                    "arguments": "{\"timezone\":\"Europe/Paris\"}"
                  }
                }
              ],
              "refusal": null
            },
            "finish_reason": "tool_calls"
          }
        ],
        "usage": {
          "prompt_tokens": 30,
          "completion_tokens": 28,
          "total_tokens": 58
        }
      },
      "has_outputs": false
    },
    "expected": {
      "result": [
        {
          "id": "call_a",
          "name": "get_weather",
          "arguments": "{\"city\":\"Paris\"}"
        },
        {
          "id": "call_b",
          "name": "get_time",
          "arguments": "{\"timezone\":\"Europe/Paris\"}"
        }
      ]
    }
  },
