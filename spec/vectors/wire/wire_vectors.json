  {
    "name": "structured_output",
    "description": "§7.1.6 — outputs converted to response_format with json_schema, strict=true, additionalProperties=false.",
    "input": {
      "provider": "openai",
      "apiType": "chat",
      "model_id": "gpt-4",
      "messages": [
        {
          "role": "user",
          "content": [{ "kind": "text", "value": "What is the weather in Paris?" }]
        }
      ],
      "tools": [],
      "options": {},
      "outputs": [
        { "name": "city", "kind": "string", "required": true },
        { "name": "temp", "kind": "integer", "required": true }
      ]
    },
    "expected": {
      "request_body": {
        "model": "gpt-4",
        "messages": [
          { "role": "user", "content": "What is the weather in Paris?" }
        ],
        "response_format": {
          "type": "json_schema",
          "json_schema": {
            "name": "structured_output",
            "strict": true,
            "schema": {
              "type": "object",
              "properties": {
                "city": { "type": "string" },
                "temp": { "type": "integer" }
              },
              "required": ["city", "temp"],
              "additionalProperties": false
            }
          }
        }
      }
    }
  },
