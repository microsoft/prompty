  {
    "name": "chat_multipart_content",
    "description": "§7.1.1/§7.1.2 — Message with TextPart + ImagePart MUST produce an array of typed content blocks.",
    "input": {
      "provider": "openai",
      "apiType": "chat",
      "model_id": "gpt-4",
      "messages": [
        {
          "role": "user",
          "content": [
            { "kind": "text", "value": "Describe this image" },
            { "kind": "image", "value": "https://img.png" }
          ]
        }
      ],
      "tools": [],
      "options": {},
      "outputs": []
    },
    "expected": {
      "request_body": {
        "model": "gpt-4",
        "messages": [
          {
            "role": "user",
            "content": [
              { "type": "text", "text": "Describe this image" },
              { "type": "image_url", "image_url": { "url": "https://img.png" } }
            ]
          }
        ]
      }
    }
  },
